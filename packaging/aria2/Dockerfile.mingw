# Reproducible 64-bit Windows aria2 build based on aria2's official
# Dockerfile.mingw from release-1.37.0.
FROM ubuntu:22.04

ARG HOST=x86_64-w64-mingw32
ARG ARIA2_COMMIT=02f2d0d8472b3c38c29b4dba8c75ebd5fdd2899a

RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        make binutils autoconf automake autotools-dev libtool patch \
        ca-certificates pkg-config git curl dpkg-dev \
        gcc-mingw-w64 g++-mingw-w64 autopoint \
        libcppunit-dev libxml2-dev libgcrypt20-dev lzip xz-utils bzip2 && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /build

RUN curl -fL --retry 3 -o gmp.tar.xz \
        https://gmplib.org/download/gmp/gmp-6.3.0.tar.xz && \
    tar xf gmp.tar.xz && \
    cd gmp-6.3.0 && \
    ./configure \
        --disable-shared --enable-static --prefix=/usr/local/$HOST \
        --host=$HOST --disable-cxx --enable-fat \
        CFLAGS="-mtune=generic -O2 -g0" && \
    make -j"$(nproc)" install

RUN curl -fL --retry 3 -o expat.tar.bz2 \
        https://github.com/libexpat/libexpat/releases/download/R_2_5_0/expat-2.5.0.tar.bz2 && \
    tar xf expat.tar.bz2 && \
    cd expat-2.5.0 && \
    ./configure \
        --disable-shared --enable-static --prefix=/usr/local/$HOST \
        --host=$HOST --build="$(dpkg-architecture -qDEB_BUILD_GNU_TYPE)" && \
    make -j"$(nproc)" install

RUN curl -fL --retry 3 -o sqlite.tar.gz \
        https://www.sqlite.org/2023/sqlite-autoconf-3430100.tar.gz && \
    tar xf sqlite.tar.gz && \
    cd sqlite-autoconf-3430100 && \
    ./configure \
        --disable-shared --enable-static --prefix=/usr/local/$HOST \
        --host=$HOST --build="$(dpkg-architecture -qDEB_BUILD_GNU_TYPE)" && \
    make -j"$(nproc)" install

RUN curl -fL --retry 3 -o zlib.tar.gz \
        https://zlib.net/fossils/zlib-1.3.tar.gz && \
    tar xf zlib.tar.gz && \
    cd zlib-1.3 && \
    CC=$HOST-gcc AR=$HOST-ar LD=$HOST-ld \
        RANLIB=$HOST-ranlib STRIP=$HOST-strip \
        ./configure --prefix=/usr/local/$HOST \
        --libdir=/usr/local/$HOST/lib \
        --includedir=/usr/local/$HOST/include --static && \
    make -j"$(nproc)" install

RUN curl -fL --retry 3 -o c-ares.tar.gz \
        https://github.com/c-ares/c-ares/releases/download/cares-1_19_1/c-ares-1.19.1.tar.gz && \
    tar xf c-ares.tar.gz && \
    cd c-ares-1.19.1 && \
    ./configure \
        --disable-shared --enable-static --without-random \
        --prefix=/usr/local/$HOST --host=$HOST \
        --build="$(dpkg-architecture -qDEB_BUILD_GNU_TYPE)" \
        LIBS="-lws2_32" && \
    make -j"$(nproc)" install

RUN curl -fL --retry 3 -o libssh2.tar.bz2 \
        https://github.com/libssh2/libssh2/releases/download/libssh2-1.11.0/libssh2-1.11.0.tar.bz2 && \
    tar xf libssh2.tar.bz2 && \
    cd libssh2-1.11.0 && \
    ./configure \
        --disable-shared --enable-static --prefix=/usr/local/$HOST \
        --host=$HOST --build="$(dpkg-architecture -qDEB_BUILD_GNU_TYPE)" \
        LIBS="-lws2_32" && \
    make -j"$(nproc)" install

RUN git clone https://github.com/aria2/aria2.git /aria2 && \
    cd /aria2 && \
    git checkout --detach "$ARIA2_COMMIT"

COPY wintls-best-effort-revocation.patch /tmp/wintls-best-effort-revocation.patch

RUN cd /aria2 && \
    git apply --check /tmp/wintls-best-effort-revocation.patch && \
    git apply /tmp/wintls-best-effort-revocation.patch && \
    tar --exclude=.git -czf /aria2-1.37.0-cove.1-source.tar.gz . && \
    autoreconf -i && \
    HOST=$HOST ./mingw-config && \
    make -j"$(nproc)" && \
    $HOST-strip src/aria2c.exe
